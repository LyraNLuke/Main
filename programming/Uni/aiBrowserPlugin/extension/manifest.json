{
  "manifest_version": 3,
  "name": "AI Task Breakdown Assistant",
  "version": "1.0.0",
  "description": "Break down your tasks into manageable subtasks with AI, and track time spent on each",
  "permissions": [
    "storage",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/content.css"]
    }
  ]
}
