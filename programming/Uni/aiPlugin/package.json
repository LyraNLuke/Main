{
  "name": "task-decomposer",
  "displayName": "Task Decomposer",
  "description": "AI-powered task decomposition with focus timer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Productivity"
  ],
  "activationEvents": [
    "onView:taskDecomposerView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "task-decomposer-container",
          "title": "Task Decomposer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "task-decomposer-container": [
        {
          "id": "taskDecomposerView",
          "name": "Task Decomposer"
        }
      ]
    },
    "commands": [
      {
        "command": "taskDecomposer.startTask",
        "title": "Start Task Decomposition"
      },
      {
        "command": "taskDecomposer.startComponent",
        "title": "Start Component Focus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.11.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.47.0",
    "@typescript-eslint/parser": "^5.47.0",
    "esbuild": "^0.16.0",
    "eslint": "^8.30.0",
    "typescript": "^4.9.0"
  }
}
